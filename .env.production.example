# Production Environment Variables for OneClaw Harness
# Copy this to .env.production on the VPS at /opt/oneclaw/.env.production

# =============================================================================
# SUPABASE (Required)
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# =============================================================================
# GOOGLE OAUTH (Required for Gmail senders)
# =============================================================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://oneclaw.chat/oauth/google/callback

# =============================================================================
# TELEGRAM NOTIFICATIONS (Optional but recommended)
# =============================================================================
# To set up:
# 1. Message @BotFather on Telegram, send /newbot
# 2. Follow prompts to create bot, copy the token
# 3. Message your new bot, then visit:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# 4. Find your chat_id in the response

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# =============================================================================
# AI PROVIDERS (Optional, for research features)
# =============================================================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
