# OneClaw Environment Configuration
# Copy this to .env.local and fill in your values

# =============================================================================
# REQUIRED - LLM API Key
# =============================================================================
# Choose ONE:
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...

# =============================================================================
# REQUIRED - Gmail OAuth (for email features)
# =============================================================================
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google/callback

# =============================================================================
# OPTIONAL - Database (choose one)
# =============================================================================
# Option A: SQLite (default, no setup needed)
# No config required - uses local file

# Option B: Supabase (cloud database)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# OPTIONAL - Business Discovery Tools
# =============================================================================
# For discover-businesses, enrich-contact tools
# APIFY_API_TOKEN=apify_api_...

# =============================================================================
# OPTIONAL - AI Search Tools
# =============================================================================
# For check-ai-rankings, match-ai-visibility tools
# PERPLEXITY_API_KEY=pplx-...

# =============================================================================
# OPTIONAL - Payments
# =============================================================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================================
# OPTIONAL - Configuration
# =============================================================================
# NODE_ENV=production
# RUST_LOG=info
